{
	"name": "surrealdb-valibot",
	"version": "1.0.1",
	"description": "Re-useable valibot schema's for use with SurrealDB sdk",
	"license": "MIT",
	"author": {
		"email": "levyvandervalk@gmail.com",
		"name": "Levy van der Valk"
	},
	"keywords": [
		"surrealdb",
		"javascript",
		"typescript",
		"schema",
		"validation",
		"type",
		"valibot"
	],
	"type": "module",
	"files": [
		"dist"
	],
	"main": "dist/surrealdbValibot.cjs",
	"module": "dist/surrealdbValibot.js",
	"types": "dist/index.d.ts",
	"exports": {
		"types": "./dist/index.d.ts",
		"import": "./dist/surrealdbValibot.js",
		"require": "./dist/surrealdbValibot.cjs"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ShadowWolf308/surrealdb-valibot"
	},
	"scripts": {
		"dev": "vite",
		"compile": "tsc && vite build",
		"preview": "vite preview",
		"production": "bun compile && npm publish",
		"lint": "biome check . --formatter-enabled=false",
		"lint:apply": "biome check . --formatter-enabled=false --write",
		"lint:apply:unsafe": "biome check . --formatter-enabled=false --write --unsafe"
	},
	"peerDependencies": {
		"surrealdb": "^1.0.6",
		"valibot": "^0.42.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"typescript": "^5.9.2",
		"vite": "^7.0.6",
		"vite-plugin-dts": "^4.5.4"
	}
}